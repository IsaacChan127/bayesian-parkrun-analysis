data_2025 <- readRDS("data/parkrun2025.rds")

# Filtering
new_obs <- data_2025 %>%
  filter(Location == "Cranbrook", Gender == "Male", Date == "2025-01-18")

# Extracting posterior draws
posterior_draws <- as_draws_df(model2_hier)

# Extracting necessary components
beta0 <- posterior_draws$b_Intercept # Intercept
beta_gender <- posterior_draws$`b_GenderMale` # Effect of being male
sigma <- posterior_draws$sigma # Residual std dev

# Extracting Cranbrook random effect
u_cranbrook_col <- grep("ˆr_Location\\[Cranbrook,Intercept\\]$", names(posterior_draws), value = TRUE)
u_cranbrook <- posterior_draws[[u_cranbrook_col]]

# Simulation (add residual noise)
set.seed(42)
n_draws <- length(beta0)
eps <- rnorm(n_draws, mean = 0, sd = sigma)

pred_times <- beta0 + beta_gender + u_cranbrook + eps

# 95% credible interval
ci_95 <- quantile(pred_times, probs = c(0.025, 0.975))
ci_95
